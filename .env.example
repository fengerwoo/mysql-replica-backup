# 复制为 .env 后，只改你实际需要的值；被注释的字段是默认值或特定模式才需要的选项。
# After copying to .env, change only the values you need; commented fields are defaults or mode-specific options.

# -----------------------------
# 项目基础配置 / Project basics
# -----------------------------

# 中文：Docker Compose 项目名，会影响容器名和卷名前缀。
# English: Docker Compose project name; affects container names and volume prefixes.
COMPOSE_PROJECT_NAME=mysql-replica-backup

# 中文：容器时区。
# English: Container timezone.
TZ=Asia/Shanghai

# 中文：MySQL 镜像版本；建议与主库 `SELECT VERSION()` 返回值一致。
# English: MySQL image version; keep it consistent with the source `SELECT VERSION()` result.
MYSQL_VERSION=8.0.45

# -----------------------------
# MySQL 主库连接信息 / Source MySQL connection
# -----------------------------

# 中文：主库地址；主库必须已开启 binlog，推荐开启 GTID。
# English: Source MySQL host; binary logging must be enabled, and GTID is recommended.
MASTER_HOST=192.168.1.10

# 中文：主库端口。
# English: Source MySQL port.
MASTER_PORT=3306

# 中文：主库复制账号；需要 REPLICATION SLAVE 和 REPLICATION CLIENT 权限。
# English: Source replication user; requires REPLICATION SLAVE and REPLICATION CLIENT privileges.
MASTER_USER=repl

# 中文：主库复制账号密码。
# English: Source replication user password.
MASTER_PASSWORD=change_me_repl_password

# -----------------------------
# 复制初始化配置 / Replication bootstrap
# -----------------------------

# 中文：首次初始化空数据目录时是否自动启动复制；已有历史数据要先导入全量时，改为 0。
# English: Whether to start replication during the first empty data-directory initialization; set to 0 before importing an initial full dump.
REPLICA_START_ON_INIT=1

# 中文：是否使用 GTID 自动定位；1 使用 SOURCE_AUTO_POSITION，0 使用 MASTER_LOG_FILE 和 MASTER_LOG_POS。
# English: Whether to use GTID auto-positioning; 1 uses SOURCE_AUTO_POSITION, 0 uses MASTER_LOG_FILE and MASTER_LOG_POS.
MASTER_AUTO_POSITION=1

# 中文：仅当 MASTER_AUTO_POSITION=0 时取消注释，填写主库 binlog 文件名。
# English: Uncomment only when MASTER_AUTO_POSITION=0, then set the source binlog file name.
# MASTER_LOG_FILE=mysql-bin.000001

# 中文：仅当 MASTER_AUTO_POSITION=0 时取消注释，填写主库 binlog 位点。
# English: Uncomment only when MASTER_AUTO_POSITION=0, then set the source binlog position.
# MASTER_LOG_POS=4

# -----------------------------
# 从库配置 / Replica settings
# -----------------------------

# 中文：从库 server-id，不能与主库或其他从库重复。
# English: Replica server-id; must be unique across the source and other replicas.
REPLICA_SERVER_ID=2001

# 中文：从库 root 密码；从库数据卷初始化后再修改此值不会改变已有 MySQL 密码。
# English: Replica root password; changing this after the replica volume is initialized will not change the existing MySQL password.
REPLICA_ROOT_PASSWORD=change_me_replica_root_password

# 中文：宿主机暴露的从库端口，容器内仍是 3306。
# English: Replica port exposed on the host; the container port remains 3306.
REPLICA_PORT=3307

# 中文：可选复制 channel 名；单源复制通常不需要。
# English: Optional replication channel name; usually unnecessary for single-source replication.
# REPLICA_CHANNEL=

# 中文：复制连接重试间隔，单位秒；默认 10。
# English: Replication connection retry interval in seconds; default is 10.
# REPLICATION_CONNECT_RETRY=10

# 中文：复制连接最大重试次数；默认 86400。
# English: Maximum replication retry count; default is 86400.
# REPLICATION_RETRY_COUNT=86400

# 中文：MySQL 从库默认时区。
# English: Default timezone used by the replica MySQL server.
MYSQL_DEFAULT_TIME_ZONE=+08:00

# -----------------------------
# 备份配置 / Backup settings
# -----------------------------

# 中文：备份容器连接从库使用的账号；默认 root，使用专用只读账号时再取消注释。
# English: User used by the backup worker to connect to the replica; default is root, uncomment only when using a dedicated read-only user.
# BACKUP_MYSQL_USER=root

# 中文：备份账号密码；默认使用 REPLICA_ROOT_PASSWORD，使用专用账号时再取消注释。
# English: Backup user password; default uses REPLICA_ROOT_PASSWORD, uncomment only when using a dedicated backup user.
# BACKUP_MYSQL_PASSWORD=change_me_replica_root_password

# 中文：是否备份所有非系统库；1 备份全部非系统库，0 只备份 BACKUP_DATABASES 指定的库。
# English: Whether to back up all non-system databases; 1 backs up all, 0 backs up only BACKUP_DATABASES.
BACKUP_ALL_DATABASES=1

# 中文：仅当 BACKUP_ALL_DATABASES=0 时取消注释，多个库名用空格分隔。
# English: Uncomment only when BACKUP_ALL_DATABASES=0; separate multiple database names with spaces.
# BACKUP_DATABASES=app_db app_db2

# 中文：备份间隔，单位秒；86400 表示每天一次，3600 表示每小时一次。
# English: Backup interval in seconds; 86400 means daily, 3600 means hourly.
BACKUP_INTERVAL_SECONDS=86400

# 中文：本地和 OSS 上保留最近 N 份备份。
# English: Number of latest backups to keep locally and in OSS.
BACKUP_RETENTION_COUNT=7

# 中文：备份文件名前缀。
# English: Backup file name prefix.
BACKUP_PREFIX=mysql-replica

# 中文：mysqldump 额外参数；通常保持默认即可，需要覆盖默认值时再取消注释。
# English: Extra mysqldump arguments; usually leave the default, and uncomment only when you need to override it.
# MYSQLDUMP_EXTRA_ARGS=--single-transaction --quick --routines --triggers --events --hex-blob

# -----------------------------
# 阿里云 OSS 配置 / Alibaba Cloud OSS settings
# -----------------------------

# 中文：OSS 提供商预留字段；当前脚本默认使用阿里云 OSS，通常不需要配置。
# English: Reserved OSS provider field; the current script uses Alibaba Cloud OSS by default, so this is usually unnecessary.
# OSS_PROVIDER=aliyun

# 中文：OSS Endpoint，例如 oss-cn-hangzhou.aliyuncs.com。
# English: OSS endpoint, for example oss-cn-hangzhou.aliyuncs.com.
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com

# 中文：OSS Bucket 名称。
# English: OSS bucket name.
OSS_BUCKET=your-bucket-name

# 中文：OSS AccessKey ID。
# English: OSS AccessKey ID.
OSS_ACCESS_KEY_ID=your-access-key-id

# 中文：OSS AccessKey Secret。
# English: OSS AccessKey Secret.
OSS_ACCESS_KEY_SECRET=your-access-key-secret

# 中文：OSS 备份路径前缀，不要以 oss://bucket 开头。
# English: OSS backup path prefix; do not include the oss://bucket part.
OSS_PREFIX=mysql-backups/prod

# 中文：透传给 ossutil 的额外参数；需要覆盖或静默确认时可取消注释，例如 -f。
# English: Extra options passed to ossutil; uncomment when you need overwrite or quiet confirmation behavior, for example -f.
# OSSUTIL_OPTIONS=-f
